{% extends 'base.html.twig' %}
{% block title %}Players — MTG Tracker{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-people me-2"></i>Players</h1>
    <a href="{{ path('player_new') }}" class="btn btn-mtg"><i class="bi bi-person-plus me-2"></i>Add Player</a>
</div>

{% if players is empty %}
<div class="card">
    <div class="card-body text-center text-muted py-5">
        <i class="bi bi-people display-4 d-block mb-3"></i>
        No players yet. <a href="{{ path('player_new') }}">Add your first player!</a>
    </div>
</div>
{% else %}
<div class="row g-3">
    {% for player in players %}
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width:48px;height:48px;background:linear-gradient(135deg,#7c3aed,#4f46e5);font-size:1.2rem;font-weight:bold">
                        {{ player.username|first|upper }}
                    </div>
                    <div>
                        <h5 class="mb-0">{{ player.username }}</h5>
                        <small class="text-muted">{{ player.email }}</small>
                    </div>
                </div>
                <div class="d-flex gap-3 mb-3">
                    <div class="text-center">
                        <div class="fw-bold">{{ player.decks|length }}</div>
                        <small class="text-muted">Decks</small>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold">{{ player.gamePlayers|length }}</div>
                        <small class="text-muted">Games</small>
                    </div>
                    <div class="text-center">
                        <div class="fw-bold" style="color:#fbbf24">
                            {{ player.gamePlayers|filter(gp => gp.winner)|length }}
                        </div>
                        <small class="text-muted">Wins</small>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('player_show', {id: player.id}) }}" class="btn btn-sm btn-outline-secondary flex-fill">View</a>
                    <a href="{{ path('player_edit', {id: player.id}) }}" class="btn btn-sm btn-outline-secondary flex-fill">Edit</a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
