{% extends 'base.html.twig' %}
{% block title %}{{ player.username }} — MTG Tracker{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <div class="rounded-circle d-flex align-items-center justify-content-center"
             style="width:56px;height:56px;background:linear-gradient(135deg,#7c3aed,#4f46e5);font-size:1.4rem;font-weight:bold">
            {{ player.username|first|upper }}
        </div>
        <div>
            <h1 class="h3 mb-0">{{ player.username }}</h1>
            <small class="text-muted">{{ player.email }}</small>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('player_edit', {id: player.id}) }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <form action="{{ path('player_delete', {id: player.id}) }}" method="post" onsubmit="return confirm('Delete this player?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ player.id) }}">
            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-4">
        <div class="card text-center">
            <div class="card-body py-3">
                <div class="h2 fw-bold" style="color:#c084fc">{{ player.gamePlayers|length }}</div>
                <small class="text-muted">Games Played</small>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card text-center">
            <div class="card-body py-3">
                <div class="h2 fw-bold" style="color:#fbbf24">{{ player.gamePlayers|filter(gp => gp.winner)|length }}</div>
                <small class="text-muted">Wins</small>
            </div>
        </div>
    </div>
    <div class="col-4">
        <div class="card text-center">
            <div class="card-body py-3">
                <div class="h2 fw-bold" style="color:#34d399">{{ player.decks|length }}</div>
                <small class="text-muted">Decks</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span><i class="bi bi-collection me-2"></i>Decks</span>
                <a href="{{ path('deck_new') }}" class="btn btn-sm btn-outline-secondary">+ Add</a>
            </div>
            <div class="card-body p-0">
                {% if player.decks is empty %}
                <p class="text-muted text-center py-4 mb-0">No decks yet.</p>
                {% else %}
                <ul class="list-group list-group-flush">
                    {% for deck in player.decks %}
                    <li class="list-group-item" style="background:transparent;border-color:#30363d;color:#e6edf3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <a href="{{ path('deck_show', {id: deck.id}) }}">{{ deck.name }}</a>
                                {% if deck.commander %}
                                <small class="text-muted d-block">{{ deck.commander }}</small>
                                {% endif %}
                            </div>
                            <span class="badge bg-format">{{ deck.format }}</span>
                        </div>
                    </li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-controller me-2"></i>Recent Games</div>
            <div class="card-body p-0">
                {% if player.gamePlayers is empty %}
                <p class="text-muted text-center py-4 mb-0">No games yet.</p>
                {% else %}
                <ul class="list-group list-group-flush">
                    {% for gp in player.gamePlayers|slice(0, 10) %}
                    <li class="list-group-item" style="background:transparent;border-color:#30363d;color:#e6edf3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <a href="{{ path('game_show', {id: gp.game.id}) }}">
                                    {{ gp.game.playedAt|date('M j, Y') }}
                                </a>
                                <small class="text-muted d-block">{{ gp.game.format }}{% if gp.deck %} · {{ gp.deck.name }}{% endif %}</small>
                            </div>
                            {% if gp.winner %}
                            <span style="color:#fbbf24"><i class="bi bi-trophy-fill"></i></span>
                            {% elseif gp.placement %}
                            <span class="text-muted">#{{ gp.placement }}</span>
                            {% endif %}
                        </div>
                    </li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
