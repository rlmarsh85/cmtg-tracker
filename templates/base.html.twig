<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MTG Tracker{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        body { background-color: #0d1117; color: #e6edf3; }
        .navbar { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-bottom: 1px solid #30363d; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; color: #c084fc !important; }
        .nav-link { color: #8b949e !important; }
        .nav-link:hover, .nav-link.active { color: #c084fc !important; }
        .card { background-color: #161b22; border: 1px solid #30363d; }
        .card-header { background-color: #1c2128; border-bottom: 1px solid #30363d; }
        .table { color: #e6edf3; }
        .table-hover tbody tr:hover { background-color: #1c2128; color: #e6edf3; }
        .btn-mtg { background: linear-gradient(135deg, #7c3aed, #4f46e5); border: none; color: white; }
        .btn-mtg:hover { background: linear-gradient(135deg, #6d28d9, #4338ca); color: white; }
        .flash-container { position: fixed; top: 70px; right: 20px; z-index: 9999; min-width: 280px; }
        .stat-card { border-left: 3px solid #7c3aed; }
        a { color: #c084fc; }
        a:hover { color: #a855f7; }
        .form-control, .form-select, textarea.form-control { background-color: #0d1117; color: #e6edf3; border-color: #30363d; }
        .form-control:focus, .form-select:focus { background-color: #0d1117; color: #e6edf3; border-color: #7c3aed; box-shadow: 0 0 0 0.2rem rgba(124, 58, 237, 0.25); }
        .participant-row { background-color: #1c2128; border: 1px solid #30363d; border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem; }
        .badge.bg-format { background-color: #1c2128 !important; border: 1px solid #30363d; color: #c084fc; }
        label.form-label { color: #8b949e; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .mtg-pip { display: inline-block; width: 12px; height: 12px; border-radius: 50%; margin-right: 2px; border: 1px solid rgba(255,255,255,0.2); vertical-align: middle; }
        .mtg-pip-White     { background-color: #f0e6c8; border-color: #999; }
        .mtg-pip-Blue      { background-color: #1e90ff; }
        .mtg-pip-Black     { background-color: #555; }
        .mtg-pip-Red       { background-color: #e03c31; }
        .mtg-pip-Green     { background-color: #2d9e3a; }
        .mtg-pip-Colorless { background-color: transparent; border: 2px solid #666; }
        .color-checkbox-label { display: flex; align-items: center; gap: 6px; cursor: pointer; padding: 6px 12px; border: 1px solid #30363d; border-radius: 6px; transition: border-color 0.15s; user-select: none; }
        .color-checkbox-label:hover { border-color: #7c3aed; }
        .color-checkbox-label .mtg-pip { width: 16px; height: 16px; margin-right: 0; }
        .color-cb-input { display: none; }
        .color-cb-input:checked + .color-checkbox-label { border-color: #7c3aed; background-color: rgba(124,58,237,0.15); }
        .cmd-thumb { height: 44px; width: auto; border-radius: 3px; vertical-align: middle; cursor: default; }
        .cmd-thumb-lg { height: 120px; width: auto; border-radius: 6px; vertical-align: middle; cursor: default; }
        #cmd-float { display: none; position: fixed; z-index: 9500; pointer-events: none; width: 220px; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.85); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <i class="bi bi-shield-fill me-2"></i>MTG Tracker
        </a>
        <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <i class="bi bi-list text-light"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link {{ app.current_route starts with 'game' ? 'active' }}" href="{{ path('game_index') }}">
                        <i class="bi bi-controller me-1"></i>Games
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.current_route starts with 'player' ? 'active' }}" href="{{ path('player_index') }}">
                        <i class="bi bi-people me-1"></i>Players
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.current_route starts with 'deck' ? 'active' }}" href="{{ path('deck_index') }}">
                        <i class="bi bi-collection me-1"></i>Decks
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.current_route starts with 'stats' ? 'active' }}" href="{{ path('stats_index') }}">
                        <i class="bi bi-pie-chart me-1"></i>Stats
                    </a>
                </li>
                <li class="nav-item ms-2">
                    <a class="btn btn-mtg btn-sm px-3" href="{{ path('game_new') }}">
                        <i class="bi bi-plus-lg me-1"></i>Record Game
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="flash-container">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show shadow" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<main class="container pb-5">
    {% block body %}{% endblock %}
</main>

<img id="cmd-float" src="" alt="">

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    const float = document.getElementById('cmd-float');
    if (!float) return;

    const W = 220, H = 308; // ~card aspect ratio at 220px wide

    function position(x, y) {
        const vw = window.innerWidth, vh = window.innerHeight;
        let left = x + 18;
        let top  = y - H / 2;
        if (left + W > vw - 8) left = x - W - 18;
        if (top < 8)           top  = 8;
        if (top + H > vh - 8)  top  = vh - H - 8;
        float.style.left = left + 'px';
        float.style.top  = top  + 'px';
    }

    document.querySelectorAll('[data-card-preview]').forEach(function (el) {
        el.addEventListener('mouseenter', function (e) {
            float.src = el.dataset.cardPreview;
            float.style.display = 'block';
            position(e.clientX, e.clientY);
        });
        el.addEventListener('mousemove', function (e) {
            position(e.clientX, e.clientY);
        });
        el.addEventListener('mouseleave', function () {
            float.style.display = 'none';
        });
    });
}());
</script>
{% block scripts %}{% endblock %}
</body>
</html>
