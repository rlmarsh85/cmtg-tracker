{% extends 'base.html.twig' %}
{% block title %}Decks — MTG Tracker{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-collection me-2"></i>Decks</h1>
    <a href="{{ path('deck_new') }}" class="btn btn-mtg"><i class="bi bi-plus-lg me-2"></i>Add Deck</a>
</div>

{% if decks is empty %}
<div class="card">
    <div class="card-body text-center text-muted py-5">
        <i class="bi bi-collection display-4 d-block mb-3"></i>
        No decks yet. <a href="{{ path('deck_new') }}">Add your first deck!</a>
    </div>
</div>
{% else %}
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Deck Name</th>
                    <th>Format</th>
                    <th>Color Identity</th>
                    <th>Commander</th>
                    <th>Owner</th>
                    <th>Games</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for deck in decks %}
                <tr>
                    <td><a href="{{ path('deck_show', {id: deck.id}) }}">{{ deck.name }}</a></td>
                    <td><span class="badge bg-format">{{ deck.format }}</span></td>
                    <td>
                        {% if deck.colorIdentity %}
                            {% if deck.colorIdentity.colors is empty %}
                                <span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>
                            {% else %}
                                {% for color in deck.colorIdentity.colors %}
                                    <span class="mtg-pip mtg-pip-{{ color.name }}" title="{{ color.name }}"></span>
                                {% endfor %}
                            {% endif %}
                            <small class="text-muted ms-1">{{ deck.colorIdentity.name }}</small>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if deck.commander %}
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <div class="d-flex align-items-center gap-1">
                                    {% if deck.commander.imageUri %}
                                        <img src="{{ deck.commander.imageUri }}" class="cmd-thumb" data-card-preview="{{ deck.commander.imageUri }}" alt="{{ deck.commander.name }}">
                                    {% endif %}
                                    <span>{{ deck.commander.name }}</span>
                                </div>
                                {% if deck.partner %}
                                    <span class="text-muted">&amp;</span>
                                    <div class="d-flex align-items-center gap-1">
                                        {% if deck.partner.imageUri %}
                                            <img src="{{ deck.partner.imageUri }}" class="cmd-thumb" data-card-preview="{{ deck.partner.imageUri }}" alt="{{ deck.partner.name }}">
                                        {% endif %}
                                        <small>{{ deck.partner.name }}</small>
                                    </div>
                                {% endif %}
                            </div>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('player_show', {id: deck.player.id}) }}">{{ deck.player.username }}</a>
                    </td>
                    <td>{{ deck.gamePlayers|length }}</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="{{ path('deck_edit', {id: deck.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <form action="{{ path('deck_delete', {id: deck.id}) }}" method="post" onsubmit="return confirm('Delete this deck?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deck.id) }}">
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
