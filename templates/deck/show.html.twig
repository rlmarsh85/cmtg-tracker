{% extends 'base.html.twig' %}
{% block title %}{{ deck.name }} — MTG Tracker{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">{{ deck.name }}</h1>
        <div class="text-muted">
            <span class="badge bg-format me-2">{{ deck.format }}</span>
            {% if deck.colorIdentity %}
                {% if deck.colorIdentity.colors is empty %}
                    <span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>
                {% else %}
                    {% for color in deck.colorIdentity.colors %}
                        <span class="mtg-pip mtg-pip-{{ color.name }}" title="{{ color.name }}"></span>
                    {% endfor %}
                {% endif %}
                <span class="me-2">{{ deck.colorIdentity.name }}</span>
            {% endif %}
            Owned by <a href="{{ path('player_show', {id: deck.player.id}) }}">{{ deck.player.username }}</a>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('deck_edit', {id: deck.id}) }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <form action="{{ path('deck_delete', {id: deck.id}) }}" method="post" onsubmit="return confirm('Delete this deck?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ deck.id) }}">
            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
    </div>
</div>

{% if deck.commander %}
<div class="card mb-4">
    <div class="card-body">
        <small class="text-muted d-block mb-3">Commander / General</small>
        <div class="d-flex align-items-start gap-4 flex-wrap">
            <div class="d-flex flex-column align-items-center gap-2">
                {% if deck.commander.imageUri %}
                    <img src="{{ deck.commander.imageUri }}" class="cmd-thumb-lg" data-card-preview="{{ deck.commander.imageUri }}" alt="{{ deck.commander.name }}">
                {% endif %}
                <div class="text-center">
                    {% if deck.commander.colorIdentity %}
                        {% if deck.commander.colorIdentity.colors is empty %}
                            <span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>
                        {% else %}
                            {% for color in deck.commander.colorIdentity.colors %}
                                <span class="mtg-pip mtg-pip-{{ color.name }}" title="{{ color.name }}"></span>
                            {% endfor %}
                        {% endif %}
                    {% endif %}
                    <strong class="ms-1">{{ deck.commander.name }}</strong>
                </div>
            </div>
            {% if deck.partner %}
                <div class="text-muted align-self-center fs-4">&amp;</div>
                <div class="d-flex flex-column align-items-center gap-2">
                    {% if deck.partner.imageUri %}
                        <img src="{{ deck.partner.imageUri }}" class="cmd-thumb-lg" data-card-preview="{{ deck.partner.imageUri }}" alt="{{ deck.partner.name }}">
                    {% endif %}
                    <div class="text-center">
                        {% if deck.partner.colorIdentity %}
                            {% if deck.partner.colorIdentity.colors is empty %}
                                <span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>
                            {% else %}
                                {% for color in deck.partner.colorIdentity.colors %}
                                    <span class="mtg-pip mtg-pip-{{ color.name }}" title="{{ color.name }}"></span>
                                {% endfor %}
                            {% endif %}
                        {% endif %}
                        <strong class="ms-1">{{ deck.partner.name }}</strong>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}

{% if deck.notes %}
<div class="card mb-4">
    <div class="card-body">
        <small class="text-muted d-block mb-1">Notes</small>
        {{ deck.notes }}
    </div>
</div>
{% endif %}

<div class="card">
    <div class="card-header"><i class="bi bi-controller me-2"></i>Games with this Deck ({{ deck.gamePlayers|length }})</div>
    {% if deck.gamePlayers is empty %}
    <div class="card-body text-muted text-center py-4">No games recorded with this deck yet.</div>
    {% else %}
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Date</th><th>Format</th><th>Players</th><th>Result</th></tr>
            </thead>
            <tbody>
                {% for gp in deck.gamePlayers %}
                <tr>
                    <td><a href="{{ path('game_show', {id: gp.game.id}) }}">{{ gp.game.playedAt|date('M j, Y') }}</a></td>
                    <td><span class="badge bg-format">{{ gp.game.format }}</span></td>
                    <td>{{ gp.game.participants|length }}</td>
                    <td>
                        {% if gp.winner %}
                        <span style="color:#fbbf24"><i class="bi bi-trophy-fill me-1"></i>Winner</span>
                        {% elseif gp.placement %}
                        #{{ gp.placement }}
                        {% else %}
                        <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
