{% extends 'base.html.twig' %}
{% block title %}{{ title }} — MTG Tracker{% endblock %}

{% block stylesheets %}
<style>
    .commander-wrapper { position: relative; }
    .autocomplete-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        right: 0;
        background: #161b22;
        border: 1px solid #7c3aed;
        border-radius: 6px;
        max-height: 280px;
        overflow-y: auto;
        z-index: 1050;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    }
    .autocomplete-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 12px;
        cursor: pointer;
        color: #e6edf3;
        font-size: 0.9rem;
        border-bottom: 1px solid #21262d;
    }
    .autocomplete-item:last-child { border-bottom: none; }
    .autocomplete-item:hover,
    .autocomplete-item.ac-active { background: #1c2128; }
    .autocomplete-pips { display: flex; gap: 3px; flex-shrink: 0; }
    .ac-loading { padding: 10px 12px; color: #8b949e; font-size: 0.85rem; }
    .partner-fixed { background-color: #1c2128 !important; color: #8b949e !important; cursor: default; }
</style>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('deck_index') }}" class="btn btn-sm btn-outline-secondary me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0">{{ title }}</h1>
        </div>
        <div class="card">
            <div class="card-body p-4">
                {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.player) }}
                    {{ form_widget(form.player) }}
                    {{ form_errors(form.player) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.format) }}
                    {{ form_widget(form.format) }}
                    {{ form_errors(form.format) }}
                </div>
                <div class="mb-3">
                    <label class="form-label">Colors</label>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        {% for choice in form.colors %}
                            {{ form_widget(choice, {'attr': {'class': 'color-cb-input'}}) }}
                            <label class="color-checkbox-label" for="{{ choice.vars.id }}">
                                <span class="mtg-pip mtg-pip-{{ choice.vars.label }}"></span>
                                {{ choice.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                    <div class="form-text text-muted mt-1">Leave all unchecked for Colorless. Auto-fills when you select a commander.</div>
                    {{ form_errors(form.colors) }}
                </div>
                <div class="mb-3" id="commander-section">
                    {{ form_label(form.commander) }}
                    <div class="commander-wrapper">
                        {{ form_widget(form.commander, {'attr': {'class': 'form-control', 'autocomplete': 'off'}}) }}
                        <div id="commander-dropdown" class="autocomplete-dropdown"></div>
                    </div>
                    {{ form_errors(form.commander) }}
                    <div class="form-text text-muted">Only required for Commander/EDH format. Selecting a suggestion auto-fills colors.</div>
                </div>
                <div class="mb-3" id="partner-section" style="display:none">
                    <label class="form-label" id="partner-section-label">Partner</label>
                    <div class="commander-wrapper">
                        {{ form_widget(form.partner, {'attr': {'class': 'form-control', 'autocomplete': 'off'}}) }}
                        <div id="partner-dropdown" class="autocomplete-dropdown"></div>
                    </div>
                    {{ form_errors(form.partner) }}
                    <div id="partner-hint" class="form-text text-muted"></div>
                </div>
                <div class="mb-4">
                    {{ form_label(form.notes) }}
                    {{ form_widget(form.notes) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-mtg flex-fill">
                        <i class="bi bi-check-lg me-2"></i>Save Deck
                    </button>
                    <a href="{{ path('deck_index') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
    const COLOR_MAP = { W: 'White', U: 'Blue', B: 'Black', R: 'Red', G: 'Green' };

    const PARTNER_LABELS = {
        partner:           'Partner Commander',
        friends_forever:   'Friends Forever Partner',
        choose_background: 'Background',
        doctors_companion: "Doctor's Companion",
        partner_with:      'Partner',
    };

    const PARTNER_HINTS = {
        partner:           'This commander can partner with any other commander that also has Partner.',
        friends_forever:   'This commander can partner with any Friends Forever commander.',
        choose_background: 'Choose a Background enchantment to pair with this commander.',
        doctors_companion: "Pair with a commander that has Doctor's Companion.",
        partner_with:      'This commander has a fixed partner — auto-filled above.',
    };

    // ── Color state ────────────────────────────────────────────────────────
    let commanderColors = [];
    let partnerColors   = [];

    function applyColors() {
        const combined = [...new Set([...commanderColors, ...partnerColors])];
        document.querySelectorAll('input.color-cb-input').forEach(cb => cb.checked = false);
        combined.forEach(l => {
            const name = COLOR_MAP[l];
            if (!name) return;
            const cb = document.querySelector('input.color-cb-input[value="' + name + '"]');
            if (cb) cb.checked = true;
        });
    }

    // ── Pip renderer ───────────────────────────────────────────────────────
    function pipsHtml(colors) {
        if (!colors || !colors.length)
            return '<span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>';
        return colors.map(l => {
            const n = COLOR_MAP[l] || l;
            return '<span class="mtg-pip mtg-pip-' + n + '" title="' + n + '"></span>';
        }).join('');
    }

    // ── Autocomplete factory ───────────────────────────────────────────────
    function makeAutocomplete(inputEl, dropdownEl, getUrl, onSelect) {
        const DEBOUNCE = 350;
        let timer = null;

        function close() { dropdownEl.style.display = 'none'; }

        function render(results) {
            dropdownEl.innerHTML = '';
            if (!results.length) { close(); return; }
            results.forEach(card => {
                const item = document.createElement('div');
                item.className = 'autocomplete-item';
                item.innerHTML =
                    '<span class="autocomplete-pips">' + pipsHtml(card.color_identity) + '</span>' +
                    '<span>' + card.name + '</span>';
                item.addEventListener('mousedown', e => {
                    e.preventDefault();
                    inputEl.value = card.name;
                    close();
                    onSelect(card);
                });
                dropdownEl.appendChild(item);
            });
            dropdownEl.style.display = 'block';
        }

        async function doFetch(q) {
            dropdownEl.innerHTML = '<div class="ac-loading"><i class="bi bi-hourglass-split me-1"></i>Searching…</div>';
            dropdownEl.style.display = 'block';
            try {
                const resp = await fetch(getUrl(q));
                if (!resp.ok) { close(); return; }
                render(await resp.json());
            } catch { close(); }
        }

        inputEl.addEventListener('input', function () {
            clearTimeout(timer);
            const q = this.value.trim();
            if (q.length < 2) { close(); return; }
            timer = setTimeout(() => doFetch(q), DEBOUNCE);
        });

        inputEl.addEventListener('keydown', function (e) {
            const items  = dropdownEl.querySelectorAll('.autocomplete-item');
            const active = dropdownEl.querySelector('.autocomplete-item.ac-active');
            if (e.key === 'Escape') { close(); return; }
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (!active) items[0]?.classList.add('ac-active');
                else { active.classList.remove('ac-active'); (active.nextElementSibling || items[0]).classList.add('ac-active'); }
                return;
            }
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (!active) items[items.length - 1]?.classList.add('ac-active');
                else { active.classList.remove('ac-active'); (active.previousElementSibling || items[items.length - 1]).classList.add('ac-active'); }
                return;
            }
            if (e.key === 'Enter') {
                const hi = dropdownEl.querySelector('.autocomplete-item.ac-active');
                if (hi && dropdownEl.style.display !== 'none') {
                    e.preventDefault();
                    hi.dispatchEvent(new MouseEvent('mousedown'));
                }
            }
        });

        inputEl.addEventListener('blur',  () => setTimeout(close, 150));
        document.addEventListener('click', e => {
            if (!inputEl.contains(e.target) && !dropdownEl.contains(e.target)) close();
        });
    }

    // ── Partner section ────────────────────────────────────────────────────
    const partnerSection  = document.getElementById('partner-section');
    const partnerLabel    = document.getElementById('partner-section-label');
    const partnerHint     = document.getElementById('partner-hint');
    const partnerInput    = document.getElementById('{{ form.partner.vars.id }}');
    const partnerDropdown = document.getElementById('partner-dropdown');
    let currentPartnerType = null;

    function showPartner(type) {
        currentPartnerType = type;
        partnerSection.style.display = '';
        partnerLabel.textContent = PARTNER_LABELS[type] || 'Partner';
        partnerHint.textContent  = PARTNER_HINTS[type]  || '';
        const isFixed = (type === 'partner_with');
        partnerInput.readOnly = isFixed;
        partnerInput.classList.toggle('partner-fixed', isFixed);
    }

    function hidePartner() {
        currentPartnerType = null;
        partnerSection.style.display = 'none';
        partnerInput.value    = '';
        partnerInput.readOnly = false;
        partnerInput.classList.remove('partner-fixed');
        partnerColors = [];
    }

    makeAutocomplete(
        partnerInput,
        partnerDropdown,
        q => '/api/commanders/partners?q=' + encodeURIComponent(q) + '&type=' + (currentPartnerType || 'partner'),
        card => {
            partnerColors = card.color_identity || [];
            applyColors();
        }
    );

    // ── Commander autocomplete ─────────────────────────────────────────────
    const cmdInput    = document.getElementById('{{ form.commander.vars.id }}');
    const cmdDropdown = document.getElementById('commander-dropdown');

    makeAutocomplete(
        cmdInput,
        cmdDropdown,
        q => '/api/commanders/search?q=' + encodeURIComponent(q),
        card => {
            commanderColors = card.color_identity || [];
            partnerColors   = [];
            applyColors();

            if (card.partner_type) {
                showPartner(card.partner_type);
                if (card.partner_type === 'partner_with' && card.partner_with) {
                    partnerInput.value = card.partner_with;
                    // Fetch the fixed partner's colors and merge them in
                    fetch('/api/commanders/info?name=' + encodeURIComponent(card.partner_with))
                        .then(r => r.ok ? r.json() : null)
                        .then(info => { if (info) { partnerColors = info.color_identity || []; applyColors(); } })
                        .catch(() => {});
                } else {
                    partnerInput.value = '';
                }
            } else {
                hidePartner();
            }
        }
    );

    // ── Format toggle ──────────────────────────────────────────────────────
    const fmtSelect  = document.getElementById('{{ form.format.vars.id }}');
    const cmdSection = document.getElementById('commander-section');

    function toggleFormat() {
        const isCommander = fmtSelect.value === 'Commander';
        cmdSection.style.display = isCommander ? '' : 'none';
        if (!isCommander) {
            cmdInput.value = '';
            cmdDropdown.style.display = 'none';
            commanderColors = [];
            hidePartner();
        }
    }

    fmtSelect.addEventListener('change', toggleFormat);
    toggleFormat();

    // ── Edit: restore partner section for existing commander ───────────────
    const savedCommander = cmdInput.value.trim();
    if (savedCommander) {
        fetch('/api/commanders/info?name=' + encodeURIComponent(savedCommander))
            .then(r => r.ok ? r.json() : null)
            .then(card => {
                if (card && card.partner_type) {
                    showPartner(card.partner_type);
                    // partner input already has its saved value from the form; leave colors alone
                }
            })
            .catch(() => {});
    }
}());
</script>
{% endblock %}
