{% extends 'base.html.twig' %}
{% block title %}{{ title }} — MTG Tracker{% endblock %}

{% block stylesheets %}
<style>
    .commander-wrapper { position: relative; }
    .autocomplete-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 2px);
        left: 0;
        right: 0;
        background: #161b22;
        border: 1px solid #7c3aed;
        border-radius: 6px;
        max-height: 280px;
        overflow-y: auto;
        z-index: 1050;
        box-shadow: 0 6px 20px rgba(0,0,0,0.5);
    }
    .autocomplete-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 12px;
        cursor: pointer;
        color: #e6edf3;
        font-size: 0.9rem;
        border-bottom: 1px solid #21262d;
    }
    .autocomplete-item:last-child { border-bottom: none; }
    .autocomplete-item:hover,
    .autocomplete-item.ac-active { background: #1c2128; }
    .autocomplete-pips { display: flex; gap: 3px; flex-shrink: 0; }
    .ac-loading { padding: 10px 12px; color: #8b949e; font-size: 0.85rem; }
</style>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('deck_index') }}" class="btn btn-sm btn-outline-secondary me-3">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="h3 mb-0">{{ title }}</h1>
        </div>
        <div class="card">
            <div class="card-body p-4">
                {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_label(form.player) }}
                    {{ form_widget(form.player) }}
                    {{ form_errors(form.player) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(form.format) }}
                    {{ form_widget(form.format) }}
                    {{ form_errors(form.format) }}
                </div>
                <div class="mb-3">
                    <label class="form-label">Colors</label>
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        {% for choice in form.colors %}
                            {{ form_widget(choice, {'attr': {'class': 'color-cb-input'}}) }}
                            <label class="color-checkbox-label" for="{{ choice.vars.id }}">
                                <span class="mtg-pip mtg-pip-{{ choice.vars.label }}"></span>
                                {{ choice.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                    <div class="form-text text-muted mt-1">Leave all unchecked for Colorless. Auto-fills when you select a commander.</div>
                    {{ form_errors(form.colors) }}
                </div>
                <div class="mb-3" id="commander-section">
                    {{ form_label(form.commander) }}
                    <div class="commander-wrapper">
                        {{ form_widget(form.commander, {'attr': {'class': 'form-control', 'autocomplete': 'off'}}) }}
                        <div id="commander-dropdown" class="autocomplete-dropdown"></div>
                    </div>
                    {{ form_errors(form.commander) }}
                    <div class="form-text text-muted">Only required for Commander/EDH format. Selecting a suggestion auto-fills colors.</div>
                </div>
                <div class="mb-4">
                    {{ form_label(form.notes) }}
                    {{ form_widget(form.notes) }}
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-mtg flex-fill">
                        <i class="bi bi-check-lg me-2"></i>Save Deck
                    </button>
                    <a href="{{ path('deck_index') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
    const input    = document.getElementById('{{ form.commander.vars.id }}');
    const dropdown = document.getElementById('commander-dropdown');
    if (!input || !dropdown) return;

    const COLOR_MAP = { W: 'White', U: 'Blue', B: 'Black', R: 'Red', G: 'Green' };
    const DEBOUNCE_MS = 350;
    let timer = null;

    // ── color checkboxes ───────────────────────────────────────────
    function setColors(colorIdentity) {
        document.querySelectorAll('input.color-cb-input').forEach(cb => cb.checked = false);
        (colorIdentity || []).forEach(letter => {
            const name = COLOR_MAP[letter];
            if (name) {
                const cb = document.querySelector('input.color-cb-input[value="' + name + '"]');
                if (cb) cb.checked = true;
            }
        });
    }

    // ── pip rendering ──────────────────────────────────────────────
    function pipsHtml(colorIdentity) {
        if (!colorIdentity || colorIdentity.length === 0) {
            return '<span class="mtg-pip mtg-pip-Colorless" title="Colorless"></span>';
        }
        return colorIdentity.map(letter => {
            const name = COLOR_MAP[letter] || letter;
            return '<span class="mtg-pip mtg-pip-' + name + '" title="' + name + '"></span>';
        }).join('');
    }

    // ── dropdown ───────────────────────────────────────────────────
    function closeDropdown() { dropdown.style.display = 'none'; }

    function renderResults(results) {
        dropdown.innerHTML = '';
        if (!results.length) { closeDropdown(); return; }

        results.forEach(card => {
            const item = document.createElement('div');
            item.className = 'autocomplete-item';
            item.innerHTML =
                '<span class="autocomplete-pips">' + pipsHtml(card.color_identity) + '</span>' +
                '<span>' + card.name + '</span>';

            item.addEventListener('mousedown', function (e) {
                e.preventDefault();                 // keep focus on input
                input.value = card.name;
                setColors(card.color_identity);
                closeDropdown();
            });

            dropdown.appendChild(item);
        });

        dropdown.style.display = 'block';
    }

    function showLoading() {
        dropdown.innerHTML = '<div class="ac-loading"><i class="bi bi-hourglass-split me-1"></i>Searching…</div>';
        dropdown.style.display = 'block';
    }

    // ── fetch ──────────────────────────────────────────────────────
    async function fetchCommanders(q) {
        showLoading();
        try {
            const resp = await fetch('/api/commanders/search?q=' + encodeURIComponent(q));
            if (!resp.ok) { closeDropdown(); return; }
            renderResults(await resp.json());
        } catch {
            closeDropdown();
        }
    }

    // ── keyboard navigation ────────────────────────────────────────
    input.addEventListener('keydown', function (e) {
        const items  = dropdown.querySelectorAll('.autocomplete-item');
        const active = dropdown.querySelector('.autocomplete-item.ac-active');

        if (e.key === 'Escape') { closeDropdown(); return; }

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (!active) { items[0]?.classList.add('ac-active'); }
            else { active.classList.remove('ac-active'); (active.nextElementSibling || items[0]).classList.add('ac-active'); }
            return;
        }

        if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (!active) { items[items.length - 1]?.classList.add('ac-active'); }
            else { active.classList.remove('ac-active'); (active.previousElementSibling || items[items.length - 1]).classList.add('ac-active'); }
            return;
        }

        if (e.key === 'Enter') {
            const highlighted = dropdown.querySelector('.autocomplete-item.ac-active');
            if (highlighted && dropdown.style.display !== 'none') {
                e.preventDefault();
                highlighted.dispatchEvent(new MouseEvent('mousedown'));
            }
        }
    });

    // ── input / focus / blur ───────────────────────────────────────
    input.addEventListener('input', function () {
        clearTimeout(timer);
        const q = this.value.trim();
        if (q.length < 2) { closeDropdown(); return; }
        timer = setTimeout(() => fetchCommanders(q), DEBOUNCE_MS);
    });

    input.addEventListener('blur', () => setTimeout(closeDropdown, 150));

    document.addEventListener('click', function (e) {
        if (!input.contains(e.target) && !dropdown.contains(e.target)) closeDropdown();
    });
}());

// ── Format → commander field visibility ────────────────────────────
(function () {
    const fmt      = document.getElementById('{{ form.format.vars.id }}');
    const section  = document.getElementById('commander-section');
    const cmdInput = document.getElementById('{{ form.commander.vars.id }}');
    const cmdDrop  = document.getElementById('commander-dropdown');
    if (!fmt || !section) return;

    function toggle() {
        const show = fmt.value === 'Commander';
        section.style.display = show ? '' : 'none';
        if (!show) {
            if (cmdInput) cmdInput.value = '';
            if (cmdDrop)  cmdDrop.style.display = 'none';
        }
    }

    fmt.addEventListener('change', toggle);
    toggle();
}());
</script>
{% endblock %}
